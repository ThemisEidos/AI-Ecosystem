{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PDA Multi-Agent Task",
  "type": "object",
  "required": [
    "task_id",
    "created",
    "command",
    "route",
    "project",
    "classification",
    "status",
    "requested_output",
    "target",
    "source",
    "assigned_worker",
    "next_worker",
    "retry_count"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "created": { "type": "string" },
    "command": { "type": "string", "pattern": "^/(planner|research|review|execute)$" },
    "route": { "type": "string", "enum": ["planner", "research", "review", "execute"] },
    "message": { "type": "string" },
    "target": { "type": "string" },
    "source_path": { "type": "string" },
    "project": { "type": "string" },
    "classification": { "type": "string", "enum": ["category_1", "category_2"] },
    "status": { "type": "string" },
    "requested_output": { "type": "string" },
    "source": { "type": "string" },
    "assigned_worker": { "type": "string", "enum": ["planner-worker", "research-worker", "review-worker", "execute-worker"] },
    "next_worker": { "type": "string" },
    "retry_count": { "type": "integer", "minimum": 0 },
    "category": { "type": "string" },
    "approved": { "type": "boolean" },
    "origin": { "type": "string" },
    "staged_path": { "type": "string" },
    "routing_surface": {
      "type": "string",
      "enum": ["local-only", "cloud-capable", "restricted-local"]
    },
    "routing_profile": {
      "type": "string",
      "enum": ["standard", "restricted_local"]
    },
    "routing_mode": {
      "type": "string",
      "enum": ["local", "cloud-capable", "fail-closed"]
    },
    "category_policy": { "type": "string" },
    "policy_enforced": { "type": "boolean" }
  },
  "additionalProperties": true
}
